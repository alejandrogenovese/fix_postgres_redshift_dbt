{
  // ─────────────────────────────────────────────────────────
  // Configuración Dev Container para VS Code
  // ─────────────────────────────────────────────────────────
  // Compatible con Docker y Podman (ver INSTALACION.md).
  //
  // Cómo usar:
  //   1. Instalar la extensión "Dev Containers" en VS Code:
  //      code --install-extension ms-vscode-remote.remote-containers
  //   2. Abrir el proyecto:  code .
  //   3. "Reopen in Container" cuando aparece el toast
  //      (O: Cmd/Ctrl+Shift+P → "Dev Containers: Reopen in Container")
  //
  // Para Podman, configurar previamente en VS Code (User Settings):
  //   "dev.containers.dockerPath": "podman"
  //   "dev.containers.dockerComposePath": "podman-compose"  (Podman 3.x)
  // ─────────────────────────────────────────────────────────

  "name": "galicia_dbt_compat",

  "dockerComposeFile": "../docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",

  "runServices": ["postgres", "dev"],
  "shutdownAction": "stopCompose",

  // ─────────────────────────────────────────────────────────
  // Setup automático al CREAR el container (no en attach).
  // - Copia profiles.yml.example a ~/.dbt/
  // - Instala packages dbt
  // - Verifica conexión
  // ─────────────────────────────────────────────────────────
  "postCreateCommand": "bash -c 'mkdir -p ~/.dbt && cp profiles.yml.example ~/.dbt/profiles.yml && dbt deps && dbt debug || true'",

  // ─────────────────────────────────────────────────────────
  // Customizaciones de VS Code dentro del container
  // ─────────────────────────────────────────────────────────
  "customizations": {
    "vscode": {
      "extensions": [
        "samuelcolvin.jinjahtml",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "redhat.vscode-yaml",
        "ms-python.python"
      ],

      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "files.associations": {
          "*.sql": "jinja-sql",
          "schema.yml": "yaml",
          "dbt_project.yml": "yaml",
          "profiles.yml": "yaml"
        },
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "files.exclude": {
          "**/target": true,
          "**/dbt_packages": true,
          "**/__pycache__": true,
          "**/.DS_Store": true
        },
        "editor.tabSize": 2,
        "[sql]": { "editor.tabSize": 4 },
        "[jinja-sql]": { "editor.tabSize": 4 },
        "terminal.integrated.defaultProfile.linux": "bash",

        "sqltools.connections": [
          {
            "name": "Local Postgres (devcontainer)",
            "driver": "PostgreSQL",
            "previewLimit": 50,
            "server": "postgres",
            "port": 5432,
            "database": "dbt_dev",
            "username": "dbt_dev",
            "askForPassword": true
          }
        ]
      }
    }
  }
}
