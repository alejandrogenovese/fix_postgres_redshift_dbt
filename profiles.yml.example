# profiles.yml.example
# ============================================================
# Plantilla de conexiones. Copiar a:
#   - Linux/macOS:  ~/.dbt/profiles.yml
#   - Windows:      %USERPROFILE%\.dbt\profiles.yml
#
# Todos los valores se pueden override con env vars. Si la env var
# no existe, usa el fallback que está como segundo argumento.
# ============================================================

galicia_dbt_compat:
  target: dev_postgres

  outputs:

    # ─── Postgres ────────────────────────────────────────────
    # Adaptativo según las env vars POSTGRES_*.
    # Defaults pensados para Postgres local en localhost:5432.
    dev_postgres:
      type: postgres
      host: "{{ env_var('POSTGRES_HOST', 'localhost') }}"
      port: "{{ env_var('POSTGRES_PORT', '5432') | int }}"
      user: "{{ env_var('POSTGRES_USER', 'dbt_dev') }}"
      password: "{{ env_var('POSTGRES_PASSWORD', 'dbt_dev_pwd') }}"
      dbname: "{{ env_var('POSTGRES_DB', 'dbt_dev') }}"
      schema: "{{ env_var('POSTGRES_SCHEMA', 'dbt_dev') }}"
      threads: 4
      sslmode: disable

    # ─── Redshift dev ────────────────────────────────────────
    # Antes de usar, exportar:
    #   export REDSHIFT_HOST=tu-cluster.xxxx.redshift.amazonaws.com
    #   export REDSHIFT_USER=tu_usuario
    #   export REDSHIFT_PWD='tu_password'
    #   export REDSHIFT_SCHEMA="${USER}_dev"
    dev_redshift:
      type: redshift
      host: "{{ env_var('REDSHIFT_HOST') }}"
      port: 5439
      user: "{{ env_var('REDSHIFT_USER') }}"
      password: "{{ env_var('REDSHIFT_PWD') }}"
      dbname: "{{ env_var('REDSHIFT_DB', 'dev') }}"
      schema: "{{ env_var('REDSHIFT_SCHEMA') }}"
      threads: 4
      ra3_node: true
      sslmode: require
